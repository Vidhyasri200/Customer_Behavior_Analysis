Q9. Are repeat buyers also likely to subscribe?

SELECT 
    subscription_status,
    COUNT(*) AS total_customers,
    AVG(previous_purchases * 1.0) AS avg_previous_purchases
FROM shopping_data
WHERE previous_purchases > 5
GROUP BY subscription_status;


