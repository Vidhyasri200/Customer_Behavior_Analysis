Q8. Top 3 most purchased products within each category

WITH product_count AS
(
    SELECT 
        category,
        item_purchased,
        COUNT(*) AS total_purchases,

        ROW_NUMBER() OVER
        (
            PARTITION BY category
            ORDER BY COUNT(*) DESC
        ) AS rn

    FROM shopping_data
    GROUP BY category, item_purchased
)

SELECT 
    category,
    item_purchased,
    total_purchases
FROM product_count
WHERE rn <= 3;


